# ──────────────────────────────────────────────────────────────
# StrideSafe — Backend environment variables
# Copy this file to .env and fill in the values.
# In Railway, set these under your service → Variables tab.
# ──────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — grants full DB access, bypasses RLS.
# Found in: Supabase dashboard → Settings → API Keys → Secret keys
# KEEP THIS SECRET — never expose it on the client side.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Strava OAuth credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret

# Must match the "Authorization Callback Domain" in your Strava API settings.
# Full URL: https://your-railway-backend.up.railway.app/strava/callback
STRAVA_REDIRECT_URI=https://your-railway-backend.up.railway.app/strava/callback

# Arbitrary secret string used to verify Strava webhook subscriptions.
# Must match what you pass to Strava when registering the webhook.
STRAVA_WEBHOOK_VERIFY_TOKEN=your-strava-webhook-verify-token

# Public URL of your deployed frontend (e.g. https://stridesafe.vercel.app)
# Used to configure CORS so the frontend can call this API.
FRONTEND_URL=https://your-frontend.vercel.app
