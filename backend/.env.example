# ──────────────────────────────────────────────────────────────
# StrideSafe — Backend environment variables
# Copy this file to .env and fill in the values below.
# ──────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — grants full DB access, bypasses RLS.
# Found in: Supabase dashboard → Settings → API Keys → Secret keys
# KEEP THIS SECRET — never expose it on the client side.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Strava OAuth credentials (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret

# Strava webhook verify token — any random string you choose.
# Supply this same value when registering the webhook subscription with Strava:
#   POST https://www.strava.com/api/v3/push_subscriptions
#     client_id=...  client_secret=...
#     callback_url=https://your-domain.com/strava/webhook
#     verify_token=<this value>
STRAVA_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
