# ──────────────────────────────────────────────────────────────
# StrideSafe — Frontend environment variables
# Copy this file to .env.local and fill in the values below.
# ──────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — safe to expose in the browser.
# Found in: Supabase dashboard → Settings → API Keys → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key — used by server-side API routes that need
# to bypass RLS (e.g. admin operations). NEVER prefix with NEXT_PUBLIC_.
# Found in: Supabase dashboard → Settings → API Keys → Secret keys
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# URL of the FastAPI backend (no trailing slash)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Strava webhook verify token — must match STRAVA_WEBHOOK_VERIFY_TOKEN in the
# backend .env. Only needed here as a reference; the backend reads it directly.
STRAVA_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
